# Backend — copy to apps/api/.env
# PostgreSQL connection string: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://abaya:changeme@localhost:5432/abaya_shop
JWT_ACCESS_SECRET=your-access-secret-min-32-chars-long-string-here
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-long-string-here
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
PORT=3001

# Frontend — copy to apps/web/.env
VITE_API_URL=http://localhost:3001/api
VITE_SOCKET_URL=http://localhost:3001
