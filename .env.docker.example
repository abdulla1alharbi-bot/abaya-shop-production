# Copy this file to .env before running: docker compose up
# Then fill in all values.

# PostgreSQL password (used by both postgres container and api container)
DB_PASSWORD=change_me_strong_password

# JWT secrets — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change_me_access_secret_64_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_64_chars

# Your VPS IP or domain name (no trailing slash)
FRONTEND_URL=http://YOUR_VPS_IP
# API base — MUST end with /api (the backend mounts every route under /api)
VITE_API_URL=http://YOUR_VPS_IP:3001/api
# Realtime notifications (Socket.IO) — the API origin WITHOUT /api
VITE_SOCKET_URL=http://YOUR_VPS_IP:3001

# Cloudinary (optional — for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
